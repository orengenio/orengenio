# OrenGen CRM — environment variables
# Set these in Coolify on the CRM application; never commit real values.

# Self-hosted Supabase (do not point at Supabase Cloud).
NEXT_PUBLIC_SUPABASE_URL=https://supacrm.orengen.io

# Public anon JWT — safe to ship to the browser. RLS is what protects data.
# Find it: Supabase Studio -> Project Settings -> API -> "anon" "public".
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...replace-me

# Server-only service-role JWT — bypasses RLS. Never NEXT_PUBLIC_*.
# Used for tenant lookup by host (subdomain routing) and admin tasks.
# Find it: Supabase Studio -> Project Settings -> API -> "service_role" "secret".
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...replace-me

# Public CRM URL. Used for OAuth redirects and absolute URLs.
NEXT_PUBLIC_APP_URL=https://app.orengen.io

# Apex host the CRM is served from. Used to detect tenant subdomains
# (anything that ends in ".${NEXT_PUBLIC_APP_HOST}" but isn't the apex).
NEXT_PUBLIC_APP_HOST=app.orengen.io

# Shared secret for cross-service calls (e.g. master Next.js -> CRM webhooks
# or CRM -> master /api/sms/send). Must match INTERNAL_API_TOKEN on the
# master Next.js app.
INTERNAL_API_TOKEN=replace-with-a-long-random-string

# CrewAI lead-qualifier service. Same value as the master Next.js app.
CREWAI_URL=https://crewai.orengen.io

# Master OrenGen Next.js app (used for cross-service calls like /api/sms/send).
OREN_MASTER_URL=https://orengen.io
