# ERPNext Configuration
# Set these in Coolify's service environment variables

# ERPNext version (Docker tag)
ERPNEXT_VERSION=v15

# Site name — must match your domain
SITE_NAME=app.orengen.io

# MariaDB root password (generate a strong one)
DB_ROOT_PASSWORD=change-me-strong-password

# ERPNext admin password (for Administrator user)
ADMIN_PASSWORD=change-me-admin-password
