# Sitebuild stack — env values set in Coolify UI (do not commit real secrets).
# Postgres
POSTGRES_USER=sitebuild
POSTGRES_PASSWORD=__SET_IN_COOLIFY__

# Payload CMS
PAYLOAD_SECRET=__SET_IN_COOLIFY__  # 64-char hex recommended; never rotate once pages exist
PAYLOAD_PUBLIC_SERVER_URL=https://admin.orengen.io

# Astro site
PUBLIC_SITE_URL=https://sitebuild.orengen.io
