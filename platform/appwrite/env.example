# Appwrite 1.8.1 — self-hosted on OrenGen infrastructure
# Deployed to https://appwrite.orengen.io via Coolify.
# Real values live in Coolify → Environment Variables UI (never commit real secrets).

# ─── Core ─────────────────────────────────────────────────────────────────────
_APP_ENV=production
_APP_WORKER_PER_CORE=6
_APP_LOCALE=en
_APP_DNS=8.8.8.8
_APP_COMPRESSION_ENABLED=enabled
_APP_COMPRESSION_MIN_SIZE_BYTES=1024

# ─── Encryption (DO NOT lose this — all stored data keyed off it) ─────────────
# 64-char hex string. Reused from prior install per operator decision.
_APP_OPENSSL_KEY_V1=__SET_IN_COOLIFY__

# ─── Domains ──────────────────────────────────────────────────────────────────
_APP_DOMAIN=appwrite.orengen.io
_APP_DOMAIN_TARGET=appwrite.orengen.io
_APP_DOMAIN_TARGET_CNAME=appwrite.orengen.io
_APP_DOMAIN_TARGET_A=
_APP_DOMAIN_TARGET_AAAA=
_APP_DOMAIN_TARGET_CAA=
_APP_DOMAIN_FUNCTIONS=functions.appwrite.orengen.io
_APP_DOMAIN_SITES=sites.appwrite.orengen.io
_APP_CUSTOM_DOMAIN_DENY_LIST=

# ─── Console whitelist ────────────────────────────────────────────────────────
_APP_CONSOLE_WHITELIST_ROOT=enabled
_APP_CONSOLE_WHITELIST_EMAILS=
_APP_CONSOLE_WHITELIST_IPS=
_APP_CONSOLE_HOSTNAMES=
_APP_CONSOLE_SESSION_ALERTS=disabled

# ─── System identity ──────────────────────────────────────────────────────────
_APP_SYSTEM_EMAIL_NAME=OrenBase
_APP_SYSTEM_EMAIL_ADDRESS=noreply@orengen.io
_APP_SYSTEM_TEAM_EMAIL=support@orengen.io
_APP_SYSTEM_SECURITY_EMAIL_ADDRESS=security@orengen.io
_APP_SYSTEM_RESPONSE_FORMAT=

# ─── HTTPS / routing options ──────────────────────────────────────────────────
# Coolify's Traefik terminates TLS upstream; keep these disabled inside Appwrite.
_APP_OPTIONS_ABUSE=enabled
_APP_OPTIONS_FORCE_HTTPS=disabled
_APP_OPTIONS_FUNCTIONS_FORCE_HTTPS=disabled
_APP_OPTIONS_ROUTER_FORCE_HTTPS=disabled
_APP_OPTIONS_ROUTER_PROTECTION=disabled

# ─── Database (MariaDB 10.11) ─────────────────────────────────────────────────
_APP_DB_HOST=mariadb
_APP_DB_PORT=3306
_APP_DB_SCHEMA=appwrite
_APP_DB_USER=__SET_IN_COOLIFY__
_APP_DB_PASS=__SET_IN_COOLIFY__
_APP_DB_ROOT_PASS=__SET_IN_COOLIFY__

# ─── Redis (7.2) ──────────────────────────────────────────────────────────────
_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379
_APP_REDIS_USER=
_APP_REDIS_PASS=

# ─── SMTP (wire up once OrenSignal / MailWizz SMTP decided) ───────────────────
_APP_SMTP_HOST=
_APP_SMTP_PORT=
_APP_SMTP_SECURE=
_APP_SMTP_USERNAME=
_APP_SMTP_PASSWORD=

# ─── SMS provider (optional) ──────────────────────────────────────────────────
_APP_SMS_PROVIDER=
_APP_SMS_FROM=

# ─── Storage (local by default — move to S3/R2 when ready) ────────────────────
_APP_STORAGE_DEVICE=local
_APP_STORAGE_LIMIT=30000000
_APP_STORAGE_PREVIEW_LIMIT=20000000
_APP_STORAGE_ANTIVIRUS=disabled
_APP_STORAGE_ANTIVIRUS_HOST=clamav
_APP_STORAGE_ANTIVIRUS_PORT=3310
_APP_STORAGE_S3_ACCESS_KEY=
_APP_STORAGE_S3_SECRET=
_APP_STORAGE_S3_REGION=us-east-1
_APP_STORAGE_S3_BUCKET=
_APP_STORAGE_S3_ENDPOINT=
_APP_STORAGE_DO_SPACES_ACCESS_KEY=
_APP_STORAGE_DO_SPACES_SECRET=
_APP_STORAGE_DO_SPACES_REGION=us-east-1
_APP_STORAGE_DO_SPACES_BUCKET=
_APP_STORAGE_BACKBLAZE_ACCESS_KEY=
_APP_STORAGE_BACKBLAZE_SECRET=
_APP_STORAGE_BACKBLAZE_REGION=us-west-004
_APP_STORAGE_BACKBLAZE_BUCKET=
_APP_STORAGE_LINODE_ACCESS_KEY=
_APP_STORAGE_LINODE_SECRET=
_APP_STORAGE_LINODE_REGION=us-east-1
_APP_STORAGE_LINODE_BUCKET=
_APP_STORAGE_WASABI_ACCESS_KEY=
_APP_STORAGE_WASABI_SECRET=
_APP_STORAGE_WASABI_REGION=us-east-1
_APP_STORAGE_WASABI_BUCKET=

# ─── Usage stats ──────────────────────────────────────────────────────────────
_APP_USAGE_STATS=enabled
_APP_USAGE_AGGREGATION_INTERVAL=30
_APP_USAGE_TIMESERIES_INTERVAL=30
_APP_USAGE_DATABASE_INTERVAL=900

# ─── Logging / APM ────────────────────────────────────────────────────────────
_APP_LOGGING_PROVIDER=
_APP_LOGGING_CONFIG=
_APP_EMAIL_SECURITY=
_APP_EMAIL_CERTIFICATES=
