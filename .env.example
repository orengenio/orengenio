# OrenGen AI Chatbot — OpenAI API Key
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Vapi Voice AI — Powers the floating orb voice assistant
# Get yours at https://dashboard.vapi.ai
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Google OAuth 2.0 — Sign in with Google
# Set up at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App URLs
NEXT_PUBLIC_BASE_URL=https://orengen.io
APP_URL=https://app.orengen.io
