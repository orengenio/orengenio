# OrenGen AI Chatbot — Anthropic API Key
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Vapi Voice AI — Powers the floating orb voice assistant
# Get yours at https://dashboard.vapi.ai
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Google OAuth 2.0 — Sign in with Google
# Set up at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# n8n — Workflow automation at automate.orengen.io
N8N_WEBHOOK_URL=https://automate.orengen.io/webhook/google-oauth-sync

# n8n — Lead capture webhook (/api/leads forwards every lead here)
# Defaults to https://automate.orengen.io/webhook/lead-capture if not set.
N8N_LEAD_WEBHOOK_URL=https://automate.orengen.io/webhook/lead-capture

# ERPNext / Frappe — Inserts a Lead doctype for every form submission.
# Live site is admin.orengen.io (renamed from app.orengen.io; CRM module
# intentionally not installed yet — the future client-login CRM lives at
# app.orengen.io as a separate app, not on this ERPNext instance).
# Leave any of these blank to skip ERPNext sync silently.
# Generate keys at <site>/app/user/<user> -> "API Access".
ERPNEXT_URL=https://admin.orengen.io
ERPNEXT_API_KEY=your-erpnext-api-key
ERPNEXT_API_SECRET=your-erpnext-api-secret

# Twilio — Account credentials. Used by both the lead-notification SMS and
# the full SMS/voice integration in /api/sms/* and /api/voice/*.
# Find ACCOUNT_SID + AUTH_TOKEN at https://console.twilio.com (Account Info).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Twilio sender(s). Prefer MessagingServiceSid for SMS once A2P 10DLC is
# approved (better deliverability + automatic number pool selection). Fall
# back to a single E.164 long code via TWILIO_PHONE_NUMBER.
TWILIO_PHONE_NUMBER=+15555550123
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dedicated voice number (the one users dial). May be the same as
# TWILIO_PHONE_NUMBER or a separate voice-only number. Used in docs and
# rendered by <ContactBar /> via NEXT_PUBLIC_OREN_PHONE.
TWILIO_VOICE_NUMBER=+15555550123

# Sales-team destination for the per-lead SMS notification (legacy).
SALES_NOTIFY_PHONE=+15555550199

# Shared secret required on POST /api/sms/send via the X-OrenGen-Token header.
# Shared with the CRM at app.orengen.io for internal cross-service auth.
# Lets internal callers (the CRM, n8n flows, CrewAI agents) trigger outbound
# SMS while blocking the public internet. Generate with `openssl rand -hex 32`.
INTERNAL_API_TOKEN=replace-with-a-long-random-string

# n8n webhook to forward every inbound SMS payload to (full Twilio params
# are POSTed as JSON). Defaults to the URL below if unset.
N8N_SMS_INBOUND_WEBHOOK=https://automate.orengen.io/webhook/sms-inbound

# n8n webhook for Twilio voice status callbacks (call started/completed/etc).
# Leave blank to skip forwarding; the route still returns 200 to Twilio.
N8N_VOICE_STATUS_WEBHOOK=https://automate.orengen.io/webhook/voice-status

# Public-facing OrenGen phone number rendered by <ContactBar /> ("Call us" /
# "Text us"). Must be NEXT_PUBLIC_* so it is inlined into the client bundle.
# Use E.164 format. If unset, the bar renders nothing.
NEXT_PUBLIC_OREN_PHONE=+15555550123

# Local-dev escape hatch: when NODE_ENV !== 'production' AND this is "1",
# the Twilio webhook routes skip X-Twilio-Signature verification (useful
# with `twilio phone-numbers:update` + ngrok). NEVER set in production.
SKIP_TWILIO_VERIFY=0

# App URLs
NEXT_PUBLIC_BASE_URL=https://orengen.io
# Client login destination (Navbar, OAuth callback, checkout). Reserved for the
# future custom CRM app — do NOT point this at ERPNext (admin.orengen.io).
APP_URL=https://app.orengen.io

# Google Analytics 4 — Measurement ID
# Find in GA4 admin → Data Streams → Web stream details (looks like G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook) Pixel ID
# Find in Meta Events Manager → Data Sources → your pixel (numeric ID)
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag — Partner ID
# Find in LinkedIn Campaign Manager → Analyze → Insight Tag (numeric Partner ID)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Stripe — payments for the OrenKanBuilder "Pay Now" path.
# Server-only secret used by /api/checkout to create Checkout Sessions.
# Get keys at https://dashboard.stripe.com/apikeys.
STRIPE_SECRET_KEY=sk_test_replace_me
# Publishable key (safe for client). Reserved for future Elements/Payment UI.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Webhook signing secret used by /api/checkout/webhook to verify events.
# Find in https://dashboard.stripe.com/webhooks after creating the endpoint.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# n8n webhooks for the Stripe checkout flow.
# /api/checkout fires a copy of the cart to this URL when a session is created.
N8N_CHECKOUT_WEBHOOK=https://automate.orengen.io/webhook/checkout-created
# /api/checkout/webhook forwards verified checkout.session.completed events.
N8N_PURCHASE_WEBHOOK=https://automate.orengen.io/webhook/purchase-completed

# CrewAI lead-qualifier service (platform/crewai).
# Base URL of the deployed FastAPI service. When unset, qualification is skipped.
CREWAI_URL=https://crewai.orengen.io
# Where CrewAI POSTs the qualification verdict for downstream automation.
N8N_QUALIFIER_RESULT_WEBHOOK=https://automate.orengen.io/webhook/lead-qualified
# Anthropic API key used by CrewAI for Claude-powered tools.
ANTHROPIC_API_KEY=sk-ant-replace-me

